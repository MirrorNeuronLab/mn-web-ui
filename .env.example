# Runtime environment: dev, development, test, prod, or production
MN_ENV=dev

# Base application directory for MirrorNeuron local state
MN_HOME=~/.mirrorneuron

# Logging: trace, debug, info, warn, or error
MN_LOG_LEVEL=info

# API service reached by the Vite development proxy
MN_API_HOST=127.0.0.1
MN_API_PORT=8000

# Web UI development server
MN_WEB_UI_HOST=127.0.0.1
MN_WEB_UI_PORT=55173

# Browser API settings
MN_WEB_API_BASE_URL=/api/v1
MN_WEB_API_TOKEN=

# Browser redirect target for run UIs
MN_GRADIO_UI_BASE_URL=http://localhost:7860

# Optional public app URL for integrations
MN_PUBLIC_APP_URL=

# Optional comma-separated origins for shared API/CLI config consumers
MN_ALLOWED_ORIGINS=

# Optional local debug UI controls
MN_ENABLE_DEBUG_PANEL=false
